# Copy this file to .env and replace every dummy secret before deployment.

# Auth.js
AUTH_SECRET="replace-with-a-long-random-auth-secret"

# PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/agency_os"
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/agency_os_test"
MIGRATION_TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/agency_os_migration_test"

# Windsor.ai server-only synchronization
WINDSOR_API_KEY="replace-with-your-windsor-api-key"
WINDSOR_DATA_BASE_URL="https://connectors.windsor.ai"
WINDSOR_ONBOARD_BASE_URL="https://onboard.windsor.ai"

# Seed-only dummy development identities. Passwords must contain at least 12
# characters. Replace these values; never use them in a public deployment.
SEED_OWNER_EMAIL="owner@example.com"
SEED_OWNER_PASSWORD="dummy-owner-password-123"
SEED_OWNER_NAME="Agency Owner"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="dummy-admin-password-123"
SEED_ADMIN_NAME="Agency Admin"
SEED_CLIENT_EMAIL="client@example.com"
SEED_CLIENT_PASSWORD="dummy-client-password-123"
SEED_CLIENT_NAME="Client User"
# The client user is assigned to the client mapped from this synchronized account.
SEED_CLIENT_EXTERNAL_ACCOUNT_ID="facebook__example-account-id"
